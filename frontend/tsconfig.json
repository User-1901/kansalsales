{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["vitest/globals", "vite/client"]
  },
  "include": ["src"],
  "exclude": [
    "src/__tests__",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "node_modules"
  ]
}
