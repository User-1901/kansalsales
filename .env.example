# ── DATABASE ───────────────────────────────────────────────────────────────
# PGlite database path (relative to project root)
DATABASE_PATH=pgdata

# ── JWT AUTHENTICATION ──────────────────────────────────────────────────────
# Secret key for signing JWT tokens - use a long random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── EMAIL SERVICE (NODEMAILER) ──────────────────────────────────────────────
# Gmail or other email provider settings for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ── RAZORPAY PAYMENT GATEWAY ────────────────────────────────────────────────
# Get these from your Razorpay dashboard: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# ── APPLICATION SETTINGS ───────────────────────────────────────────────────
# Client origin for CORS (where frontend is hosted)
CLIENT_ORIGIN=http://localhost:5173

# Server port
PORT=3000

# Environment: development, test, production
NODE_ENV=development
